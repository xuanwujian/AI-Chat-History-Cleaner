{
  "manifest_version": 3,
  "name": "ChatEraser - 清聊大师",
  "version": "3.0.5",
  "description": "Bulk delete your AI chat conversation history with one click. Fast, private, and fully local — no data leaves your browser.",
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs",
    "debugger",
    "history"
  ],
  "host_permissions": [
    "*://chat.openai.com/*",
    "*://chatgpt.com/*",
    "*://claude.ai/*",
    "*://gemini.google.com/*",
    "*://chat.deepseek.com/*",
    "*://kimi.moonshot.cn/*",
    "*://www.kimi.com/*",
    "*://kimi.com/*",
    "*://www.doubao.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "ChatEraser 清聊大师",
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://chat.openai.com/*",
        "*://chatgpt.com/*",
        "*://claude.ai/*",
        "*://gemini.google.com/*",
        "*://chat.deepseek.com/*",
        "*://kimi.moonshot.cn/*",
        "*://www.kimi.com/*",
        "*://kimi.com/*",
        "*://www.doubao.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["injected.js"],
      "matches": [
        "*://chat.openai.com/*",
        "*://chatgpt.com/*",
        "*://claude.ai/*",
        "*://gemini.google.com/*",
        "*://chat.deepseek.com/*",
        "*://kimi.moonshot.cn/*",
        "*://www.kimi.com/*",
        "*://kimi.com/*",
        "*://www.doubao.com/*"
      ]
    }
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  }
}
